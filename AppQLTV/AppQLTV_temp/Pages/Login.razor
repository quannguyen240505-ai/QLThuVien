@page "/login"
@using System.Net.Http.Json
@using AppQLTV.Models.Auth
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Đăng nhập</PageTitle>

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-header">
            <div class="auth-icon">
                <i class="bi bi-person-circle"></i>
            </div>

            <h1>Đăng nhập</h1>
            <p>Truy cập hệ thống thư viện đại học</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert">
                @errorMessage
            </div>
        }
        <div class="social-login">
            <button class="social-btn google-btn" type="button">
                <i class="bi bi-google"></i>
                <span>Đăng nhập với Google</span>
            </button>

            <button class="social-btn facebook-btn" type="button">
                <i class="bi bi-facebook"></i>
                <span>Đăng nhập với Facebook</span>
            </button>
        </div>

        <div class="auth-divider">
            <span>hoặc đăng nhập bằng tài khoản</span>
        </div>

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Username</label>
                <InputText class="form-control"
                           @bind-Value="loginModel.Username"
                           placeholder="Nhập tên đăng nhập" />
                <ValidationMessage For="@(() => loginModel.Username)" />
            </div>

            <div class="form-group">
                <label>Password</label>
                <InputText class="form-control"
                           type="password"
                           @bind-Value="loginModel.Password"
                           placeholder="Nhập mật khẩu" />
                <ValidationMessage For="@(() => loginModel.Password)" />
            </div>

            <button class="auth-submit" type="submit" disabled="@isLoading">
                @(isLoading ? "Đang đăng nhập..." : "Đăng nhập")
            </button>
            <div class="remember-row">
                <span></span>
                <a href="forgot-password">Quên mật khẩu?</a>
            </div>
        </EditForm>


        <div class="auth-footer">
            Chưa có tài khoản?
            <a href="register">Đăng ký ngay</a>
        </div>

    </div>
</div>

@code {
    private LoginRequest loginModel = new();
    private string errorMessage = "";
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/login", loginModel);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Tên đăng nhập hoặc mật khẩu không đúng.";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<AuthResponse>();

            if (result == null || string.IsNullOrWhiteSpace(result.Token))
            {
                errorMessage = "Đăng nhập thất bại.";
                return;
            }

            await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
            await JS.InvokeVoidAsync("localStorage.setItem", "username", result.Username);
            await JS.InvokeVoidAsync("localStorage.setItem", "gmail", result.Gmail);
            await JS.InvokeVoidAsync("localStorage.setItem", "role", result.Role);
            await JS.InvokeVoidAsync("localStorage.setItem", "tokenExpiration", result.Expiration.ToString("O"));

            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch
        {
            errorMessage = "Không thể kết nối đến máy chủ API.";
        }
        finally
        {
            isLoading = false;
        }
    }
}