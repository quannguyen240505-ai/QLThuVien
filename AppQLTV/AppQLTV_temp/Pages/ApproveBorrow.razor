@page "/approve-borrow"
@using AppQLTV.Models
@using AppQLTV.Services
@inject IBorrowService BorrowService

<h3>✅ Duyệt yêu cầu mượn sách</h3>

@if (requests == null)
{
    <p>Đang tải...</p>
}
else if (requests.Count == 0)
{
    <div class="alert alert-success">Không có yêu cầu nào chờ duyệt.</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr><th>Người dùng</th><th>Sách</th><th>Ngày yêu cầu</th><th>Ghi chú</th><th>Hành động</th></tr>
        </thead>
        <tbody>
            @foreach (var r in requests)
            {
                <tr>
                    <td>@r.UserName</td>
                    <td>@r.BookTitle</td>
                    <td>@r.RequestDate.ToString("dd/MM/yyyy")</td>
                    <td>@r.Notes</td>
                    <td>
                        <button class="btn btn-sm btn-success" @onclick="() => Approve(r.Id, true)">Duyệt</button>
                        <button class="btn btn-sm btn-danger ms-1" @onclick="() => Approve(r.Id, false)">Từ chối</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<BorrowRequest>? requests;

    protected override async Task OnInitializedAsync()
    {
        await LoadRequests();
    }

    private async Task LoadRequests()
    {
        requests = await BorrowService.GetPendingRequestsAsync();
        StateHasChanged();
    }

    private async Task Approve(int id, bool isApproved)
    {
        var reason = isApproved ? null : "Từ chối bởi thủ thư";
        await BorrowService.ApproveRequestAsync(id, isApproved, reason);
        await LoadRequests();
    }
}