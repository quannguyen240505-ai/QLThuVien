@page "/books/create"
@using AppQLTV.Models
@using AppQLTV.Services
@inject IBookService BookService
@inject NavigationManager Navigation

<h3>➕ Thêm sách mới</h3>

<EditForm Model="@newBook" OnValidSubmit="@HandleCreate">
    <div class="mb-3">
        <label>Tiêu đề</label>
        <InputText @bind-Value="newBook.Title" class="form-control" />
        <ValidationMessage For="@(() => newBook.Title)" />
    </div>
    <div class="mb-3">
        <label>Tác giả</label>
        <InputText @bind-Value="newBook.Author" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Thể loại</label>
        <InputText @bind-Value="newBook.Category" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Nhà xuất bản</label>
        <InputText @bind-Value="newBook.Publisher" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Năm xuất bản</label>
        <InputNumber @bind-Value="newBook.PublishYear" class="form-control" />
    </div>
    <div class="mb-3">
        <label>Số lượng (tổng)</label>
        <InputNumber @bind-Value="newBook.Quantity" class="form-control" min="0" />
    </div>
    <div class="mb-3">
        <label>Mô tả</label>
        <InputTextArea @bind-Value="newBook.Description" class="form-control" />
    </div>
    <div class="mb-3">
        <label>URL ảnh</label>
        <InputText @bind-Value="newBook.ImageUrl" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Lưu</button>
    <a href="/books" class="btn btn-secondary">Hủy</a>
</EditForm>

@code {
    private Book newBook = new Book();

    private async Task HandleCreate()
    {
        await BookService.CreateBookAsync(newBook);
        Navigation.NavigateTo("/books");
    }
}