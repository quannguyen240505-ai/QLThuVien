@page "/borrow-history"
@using AppQLTV.Models
@using AppQLTV.Services
@inject IBorrowService BorrowService

<h3>📜 Lịch sử mượn sách</h3>

@if (requests == null)
{
    <p>Đang tải...</p>
}
else if (requests.Count == 0)
{
    <div class="alert alert-warning">Bạn chưa có yêu cầu mượn nào.</div>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr><th>Sách</th><th>Ngày yêu cầu</th><th>Trạng thái</th><th>Hạn trả</th><th>Ngày trả</th><th>Ghi chú</th></tr>
        </thead>
        <tbody>
            @foreach (var r in requests)
            {
                <tr>
                    <td>@r.BookTitle</td>
                    <td>@r.RequestDate.ToString("dd/MM/yyyy")</td>
                    <td>@r.Status</td>
                    <td>@(r.DueDate?.ToString("dd/MM/yyyy") ?? "")</td>
                    <td>@(r.ReturnDate?.ToString("dd/MM/yyyy") ?? "")</td>
                    <td>@r.Notes</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AppQLTV.Models.BorrowRequest>? requests;   // ← dùng fully qualified name

    protected override async Task OnInitializedAsync()
    {
        requests = await BorrowService.GetMyRequestsAsync();
    }
}