@page "/return-books"
@using System.Net.Http.Json
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS

<h3>📥 Trả sách</h3>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info">@message</div>
}

@if (isLoading)
{
    <p>Đang tải...</p>
}
else if (borrowings.Count == 0)
{
    <div class="alert alert-success">
        Bạn hiện không có sách nào đang mượn.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Mã phiếu</th>
                <th>Sách đang mượn</th>
                <th>Ngày mượn</th>
                <th>Hạn trả</th>
                <th>Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in borrowings)
            {
                <tr>
                    <td>#@item.BorrowTicketId</td>

                    <td>
                        @foreach (var detail in item.Details)
                        {
                            <div>@detail.BookTitle - SL: @detail.Quantity</div>
                        }
                    </td>

                    <td>@item.BorrowDate.ToString("dd/MM/yyyy")</td>
                    <td>@item.DueDate.ToString("dd/MM/yyyy")</td>

                    <td>
                        <button class="btn btn-warning"
                                @onclick="() => ReturnBook(item.BorrowTicketId)">
                            Xác nhận trả sách
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<MyBorrowingModel> borrowings = new();
    private bool isLoading = true;
    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadMyBorrowingBooks();
    }

    private async Task SetToken()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        if (!string.IsNullOrWhiteSpace(token))
        {
            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadMyBorrowingBooks()
    {
        isLoading = true;
        message = "";

        await SetToken();

        borrowings =
            await Http.GetFromJsonAsync<List<MyBorrowingModel>>("api/Borrow/my-borrowing")
            ?? new();

        isLoading = false;
    }

    private async Task ReturnBook(int ticketId)
    {
        await SetToken();

        var response = await Http.PutAsync($"api/Borrow/{ticketId}/member-return", null);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ReturnResult>();

            if (result != null)
            {
                message = $"✅ Trả sách thành công. Quá hạn: {result.OverdueDays} ngày. Phí phạt: {result.FineAmount:N0} VNĐ.";
            }
            else
            {
                message = "✅ Trả sách thành công.";
            }

            await LoadMyBorrowingBooks();
        }
        else
        {
            message = await response.Content.ReadAsStringAsync();
        }
    }

    public class MyBorrowingModel
    {
        public int BorrowTicketId { get; set; }
        public DateTime BorrowDate { get; set; }
        public DateTime DueDate { get; set; }
        public string Status { get; set; } = "";
        public List<MyBorrowingDetailModel> Details { get; set; } = new();
    }

    public class MyBorrowingDetailModel
    {
        public int BorrowDetailId { get; set; }
        public int BookId { get; set; }
        public string BookTitle { get; set; } = "";
        public int Quantity { get; set; }
        public string Status { get; set; } = "";
    }

    public class ReturnResult
    {
        public string Message { get; set; } = "";
        public int OverdueDays { get; set; }
        public int FineAmount { get; set; }
    }
}