@page "/librarian/books"
@using AppQLTV.Models
@using Microsoft.AspNetCore.Authorization
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@attribute [Authorize(Roles = "Librarian,Admin")]

<h3>📚 Quản lý sách</h3>

<button class="btn btn-primary mb-3" @onclick="() => { isEditing = false; currentBook = new Book(); showForm = true; }">
    + Thêm sách mới
</button>

@if (showForm)
{
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-info text-white">@(isEditing ? "Sửa sách" : "Thêm sách")</div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6 mb-2">
                    <label>Tên sách</label>
                    <input @bind="currentBook.Title" class="form-control" />
                </div>
                <div class="col-md-6 mb-2">
                    <label>Tác giả</label>
                    <input @bind="currentBook.Author" class="form-control" />
                </div>
                <div class="col-md-6 mb-2">
                    <label>Nhà xuất bản</label>
                    <input @bind="currentBook.Publisher" class="form-control" />
                </div>
                <div class="col-md-6 mb-2">
                    <label>Thể loại</label>
                    <input @bind="currentBook.Category" class="form-control" />
                </div>
                <div class="col-md-3 mb-2">
                    <label>Năm XB</label>
                    <input @bind="currentBook.PublishYear" class="form-control" type="number" />
                </div>
                <div class="col-md-3 mb-2">
                    <label>ISBN</label>
                    <input @bind="currentBook.ISBN" class="form-control" />
                </div>
                <div class="col-md-3 mb-2">
                    <label>Tổng số lượng</label>
                    <input @bind="currentBook.TotalCopies" class="form-control" type="number" />
                </div>
                <div class="col-md-12 mb-2">
                    <label>Mô tả</label>
                    <textarea @bind="currentBook.Description" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="mt-3">
                <button class="btn btn-success" @onclick="SaveBook">💾 Lưu</button>
                <button class="btn btn-secondary" @onclick="() => showForm = false">❌ Hủy</button>
            </div>
        </div>
    </div>
}

<table class="table table-bordered table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Tên sách</th>
            <th>Tác giả</th>
            <th>Thể loại</th>
            <th>Số lượng</th>
            <th>Khả dụng</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @if (books != null)
        {
            foreach (var book in books)
            {
                <tr>
                    <td>@book.Id</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Category</td>
                    <td>@book.TotalCopies</td>
                    <td>@book.AvailableCopies</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => { currentBook = book; isEditing = true; showForm = true; }">✏️ Sửa</button>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteBook(book.Id)">🗑️ Xóa</button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="7" class="text-center">Đang tải...</td></tr>
        }
    </tbody>
</table>

@code {
    private List<Book>? books;
    private Book currentBook = new();
    private bool showForm = false;
    private bool isEditing = false;

    protected override async Task OnInitializedAsync() => await LoadBooks();

    private async Task LoadBooks() => books = await Http.GetFromJsonAsync<List<Book>>("api/books");

    private async Task SaveBook()
    {
        if (isEditing)
            await Http.PutAsJsonAsync($"api/books/{currentBook.Id}", currentBook);
        else
            await Http.PostAsJsonAsync("api/books", currentBook);
        await LoadBooks();
        showForm = false;
    }

    private async Task DeleteBook(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn xóa sách này không?"))
        {
            await Http.DeleteAsync($"api/books/{id}");
            await LoadBooks();
        }
    }
}