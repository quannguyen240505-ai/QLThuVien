@page "/librarian/books"
@using AppQLTV.Models
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Headers
@using System.Text.Json
@using System.Text
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<!-- PHẦN HTML GIỮ NGUYÊN NHƯ BẠN ĐÃ CÓ, KHÔNG CẦN SỬA -->
<div class="container-fluid px-4">
    <div class="d-flex justify-content-between align-items-center mt-3 mb-4">
        <h3 class="text-primary"><i class="bi bi-journal-bookmark-fill"></i> Quản lý sách</h3>
        <button class="btn btn-success rounded-pill px-4" @onclick="OpenCreateForm">
            <i class="bi bi-plus-lg"></i> Thêm sách mới
        </button>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="row g-2 align-items-center">
                <div class="col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" placeholder="Tìm theo tên sách, tác giả..."
                               @bind="searchKeyword" @bind:event="oninput" />
                    </div>
                </div>
                <div class="col-md-auto">
                    <button class="btn btn-outline-secondary" @onclick="ClearSearch">
                        <i class="bi bi-eraser"></i> Xóa
                    </button>
                </div>
                <div class="col-md-auto ms-auto">
                    <span class="badge bg-secondary">Tổng: @(filteredBooks?.Count() ?? 0) sách</span>
                </div>
            </div>
        </div>
    </div>

    @if (showForm)
    {
        <div class="card shadow-lg mb-4 border-0">
            <div class="card-header bg-primary text-white fw-bold">
                @(isEditing ? "✏️ Chỉnh sửa sách" : "📖 Thêm sách mới")
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Tên sách <span class="text-danger">*</span></label>
                        <input @bind="currentBook.Title" class="form-control" placeholder="Nhập tên sách" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Tác giả <span class="text-danger">*</span></label>
                        <input @bind="currentBook.Author" class="form-control" placeholder="Nhập tên tác giả" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Nhà xuất bản</label>
                        <input @bind="currentBook.Publisher" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Thể loại</label>
                        <input @bind="currentBook.Category" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">Năm XB</label>
                        <input @bind="currentBook.PublishYear" class="form-control" type="number" />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-semibold">ISBN</label>
                        <input @bind="currentBook.ISBN" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-semibold">Tổng số lượng</label>
                        <input @bind="currentBook.TotalCopies" class="form-control" type="number" min="0" />
                    </div>
                    <div class="col-md-9">
                        <label class="form-label fw-semibold">URL ảnh bìa</label>
                        <input @bind="currentBook.CoverImageUrl" class="form-control" placeholder="https://example.com/cover.jpg" />
                        <small class="text-muted">Nhập đường dẫn ảnh (nếu có)</small>
                    </div>
                    <div class="col-md-12">
                        <label class="form-label fw-semibold">Mô tả</label>
                        <textarea @bind="currentBook.Description" class="form-control" rows="2"></textarea>
                    </div>
                </div>
                <div class="mt-4 d-flex gap-2 justify-content-end">
                    <button class="btn btn-secondary rounded-pill px-4" @onclick="CancelForm">Hủy</button>
                    <button class="btn btn-primary rounded-pill px-4" @onclick="SaveBook">
                        <i class="bi bi-save"></i> Lưu
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th style="width: 60px">ID</th>
                            <th style="width: 80px">Ảnh bìa</th>
                            <th>Tên sách</th>
                            <th>Tác giả</th>
                            <th>Thể loại</th>
                            <th class="text-center">SL</th>
                            <th class="text-center">Khả dụng</th>
                            <th style="width: 120px">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (isLoading)
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status"></div>
                                    <p class="mt-2">Đang tải...</p>
                                </td>
                            </tr>
                        }
                        else if (filteredBooks == null || !filteredBooks.Any())
                        {
                            <tr>
                                <td colspan="8" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox" style="font-size: 2rem;"></i>
                                    <p class="mt-2">Không có sách nào.</p>
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var book in filteredBooks)
                            {
                                <tr>
                                    <td>@book.Id</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                                        {
                                            <img src="@book.CoverImageUrl" alt="cover" style="width: 50px; height: 70px; object-fit: cover; border-radius: 6px;" />
                                        }
                                        else
                                        {
                                            <div style="width: 50px; height: 70px; background: #f0f0f0; display: flex; align-items: center; justify-content: center; border-radius: 6px;">
                                                <i class="bi bi-journal-bookmark-fill" style="font-size: 1.8rem; color: #aaa;"></i>
                                            </div>
                                        }
                                    </td>
                                    <td><strong>@book.Title</strong></td>
                                    <td>@book.Author</td>
                                    <td>@(book.Category ?? "—")</td>
                                    <td class="text-center">@book.TotalCopies</td>
                                    <td class="text-center">
                                        <span class="badge @(book.AvailableCopies > 0 ? "bg-success" : "bg-danger") rounded-pill">
                                            @book.AvailableCopies
                                        </span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm">
                                            <button class="btn btn-outline-primary" @onclick="() => EditBook(book)" title="Sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            <button class="btn btn-outline-danger" @onclick="() => DeleteBook(book.Id)" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Book>? books;
    private List<Book> filteredBooks = new();
    private Book currentBook = new();
    private bool showForm = false;
    private bool isEditing = false;
    private bool isLoading = true;
    private string _searchKeyword = "";

    private string searchKeyword
    {
        get => _searchKeyword;
        set
        {
            if (_searchKeyword != value)
            {
                _searchKeyword = value;
                ApplyFilter();
            }
        }
    }

    // ========== TOKEN HANDLING ==========
    private async Task<string?> GetAccessTokenAsync()
    {
        try
        {
            // Thử lấy token với nhiều key phổ biến
            string[] possibleKeys = { "accessToken", "token", "authToken", "access_token" };
            foreach (var key in possibleKeys)
            {
                var token = await JS.InvokeAsync<string>("localStorage.getItem", key);
                if (!string.IsNullOrEmpty(token))
                {
                    Console.WriteLine($"Found token with key: {key}");
                    return token;
                }
            }
            Console.WriteLine("No token found in localStorage");
            return null;
        }
        catch (JSException ex)
        {
            Console.WriteLine($"JSException: {ex.Message}");
            return null;
        }
    }

    private async Task<HttpResponseMessage> SendAuthorizedAsync(HttpMethod method, string url, object? body = null)
    {
        var token = await GetAccessTokenAsync();
        var request = new HttpRequestMessage(method, url);

        if (!string.IsNullOrEmpty(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            Console.WriteLine($"Added Authorization header for {method} {url}");
        }
        else
        {
            Console.WriteLine("No token available, request will be unauthorized");
        }

        if (body != null)
        {
            request.Content = new StringContent(
                JsonSerializer.Serialize(body),
                Encoding.UTF8,
                "application/json");
        }

        // Gửi request
        var response = await Http.SendAsync(request);

        // Nếu lỗi 401, xóa token cũ (nếu có) và thông báo
        if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            Console.WriteLine($"401 Unauthorized for {url}");
            // Xóa token cũ (không rõ key nào, thử xóa các key phổ biến)
            string[] possibleKeys = { "accessToken", "token", "authToken", "access_token" };
            foreach (var key in possibleKeys)
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", key);
            }
            await JS.InvokeVoidAsync("alert", "Phiên đăng nhập hết hạn. Vui lòng đăng nhập lại.");
            Navigation.NavigateTo("/login", true);
        }
        return response;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        isLoading = true;
        try
        {
            var response = await SendAuthorizedAsync(HttpMethod.Get, "api/books");
            if (response.IsSuccessStatusCode)
            {
                var json = await response.Content.ReadAsStringAsync();
                books = JsonSerializer.Deserialize<List<Book>>(json, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                filteredBooks = books ?? new();
                Console.WriteLine($"Loaded {filteredBooks.Count} books");
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Load error: {response.StatusCode} - {error}");
                await JS.InvokeVoidAsync("alert", $"Lỗi tải sách: {response.StatusCode}\n{error}");
                filteredBooks = new();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception: {ex.Message}");
            await JS.InvokeVoidAsync("alert", $"Lỗi kết nối: {ex.Message}");
            filteredBooks = new();
        }
        finally
        {
            isLoading = false;
            ApplyFilter();
        }
    }

    private void OpenCreateForm()
    {
        currentBook = new Book
        {
            TotalCopies = 1,
            AvailableCopies = 1,
            PublishYear = DateTime.Now.Year
        };
        isEditing = false;
        showForm = true;
    }

    private void EditBook(Book book)
    {
        currentBook = new Book
        {
            Id = book.Id,
            Title = book.Title,
            Author = book.Author,
            ISBN = book.ISBN,
            Publisher = book.Publisher,
            PublishYear = book.PublishYear,
            Category = book.Category,
            Description = book.Description,
            TotalCopies = book.TotalCopies,
            AvailableCopies = book.AvailableCopies,
            CoverImageUrl = book.CoverImageUrl
        };
        isEditing = true;
        showForm = true;
    }

    private async Task SaveBook()
    {
        if (string.IsNullOrWhiteSpace(currentBook.Title) || string.IsNullOrWhiteSpace(currentBook.Author))
        {
            await JS.InvokeVoidAsync("alert", "Vui lòng nhập đầy đủ tên sách và tác giả!");
            return;
        }

        if (currentBook.TotalCopies < 0) currentBook.TotalCopies = 0;
        if (!isEditing)
        {
            currentBook.AvailableCopies = currentBook.TotalCopies;
        }
        else
        {
            if (currentBook.AvailableCopies > currentBook.TotalCopies)
                currentBook.AvailableCopies = currentBook.TotalCopies;
        }

        try
        {
            HttpResponseMessage response;
            if (isEditing)
                response = await SendAuthorizedAsync(HttpMethod.Put, $"api/books/{currentBook.Id}", currentBook);
            else
                response = await SendAuthorizedAsync(HttpMethod.Post, "api/books", currentBook);

            if (response.IsSuccessStatusCode)
            {
                await LoadBooks();
                showForm = false;
                await JS.InvokeVoidAsync("alert", isEditing ? "Cập nhật sách thành công!" : "Thêm sách thành công!");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Lỗi {response.StatusCode}: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Lỗi: {ex.Message}");
        }
    }

    private async Task DeleteBook(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Bạn có chắc chắn muốn xóa sách này không?"))
        {
            try
            {
                var response = await SendAuthorizedAsync(HttpMethod.Delete, $"api/books/{id}");
                if (response.IsSuccessStatusCode)
                {
                    await LoadBooks();
                    await JS.InvokeVoidAsync("alert", "Xóa sách thành công!");
                }
                else
                {
                    var errorContent = await response.Content.ReadAsStringAsync();
                    await JS.InvokeVoidAsync("alert", $"Lỗi xóa: {response.StatusCode} - {errorContent}");
                }
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Lỗi: {ex.Message}");
            }
        }
    }

    private void CancelForm()
    {
        showForm = false;
        currentBook = new();
    }

    private void ClearSearch()
    {
        searchKeyword = "";
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (string.IsNullOrWhiteSpace(searchKeyword))
            filteredBooks = books ?? new();
        else
        {
            var kw = searchKeyword.ToLower();
            filteredBooks = books?.Where(b =>
                (b.Title?.ToLower().Contains(kw) ?? false) ||
                (b.Author?.ToLower().Contains(kw) ?? false) ||
                (b.Category?.ToLower().Contains(kw) ?? false)
            ).ToList() ?? new();
        }
        StateHasChanged();
    }
}