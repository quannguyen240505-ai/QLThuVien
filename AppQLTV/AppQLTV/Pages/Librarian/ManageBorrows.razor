@page "/librarian/borrows"
@using System.Net.Http.Json
@using System.Net.Http.Headers
@using AppQLTV.Models.Library
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Duyệt mượn/trả sách</PageTitle>

<div class="manage-borrows-page">
    <div class="manage-borrows-header">
        <div>
            <h2>🔄 Duyệt mượn/trả sách</h2>
            <p>Quản lý yêu cầu mượn sách, duyệt mượn và xác nhận trả sách</p>
        </div>

        <button class="btn btn-light" @onclick="LoadBorrows">
            Làm mới
        </button>
    </div>

    <div class="borrow-status-filter">
        <button class="btn @(currentStatus == "All" ? "btn-secondary" : "btn-outline-secondary")"
                @onclick='() => SetStatus("All")'>
            Tất cả (@borrowTickets.Count)
        </button>

        <button class="btn @(currentStatus == "Pending" ? "btn-warning" : "btn-outline-warning")"
                @onclick='() => SetStatus("Pending")'>
            Chờ duyệt (@borrowTickets.Count(x => x.Status == "Pending"))
        </button>

        <button class="btn @(currentStatus == "Borrowing" ? "btn-primary" : "btn-outline-primary")"
                @onclick='() => SetStatus("Borrowing")'>
            Đang mượn (@borrowTickets.Count(x => x.Status == "Borrowing"))
        </button>

        <button class="btn @(currentStatus == "Returned" ? "btn-success" : "btn-outline-success")"
                @onclick='() => SetStatus("Returned")'>
            Đã trả (@borrowTickets.Count(x => x.Status == "Returned"))
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center mt-4">
            <div class="spinner-border"></div>
            <p>Đang tải dữ liệu...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-warning mt-3">
            @errorMessage
        </div>
    }
    else if (FilteredTickets.Count == 0)
    {
        <div class="alert alert-info mt-3">
            Không có phiếu mượn nào.
        </div>
    }
    else
    {
        <div class="borrow-card-list mt-3">
            @foreach (var ticket in FilteredTickets)
            {
                <div class="borrow-ticket-card">
                    <div class="ticket-top">
                        <div>
                            <h5>@ticket.ReaderName</h5>
                            <span>Mã phiếu: #@ticket.BorrowTicketId</span>
                        </div>

                        <span class="ticket-status @GetStatusClass(ticket.Status)">
                            @GetStatusText(ticket.Status)
                        </span>
                    </div>

                    <div class="ticket-info">
                        <div>
                            <small>Ngày mượn</small>
                            <strong>@ticket.BorrowDate.ToString("dd/MM/yyyy")</strong>
                        </div>

                        <div>
                            <small>Hạn trả</small>
                            <strong>@ticket.DueDate.ToString("dd/MM/yyyy")</strong>
                        </div>

                        <div>
                            <small>Ngày trả</small>
                            <strong>@(ticket.ReturnDate?.ToString("dd/MM/yyyy") ?? "Chưa trả")</strong>
                        </div>
                    </div>

                    <div class="ticket-books">
                        <strong>Sách mượn</strong>

                        @if (ticket.Details == null || ticket.Details.Count == 0)
                        {
                            <p class="text-muted mb-0">Không có chi tiết sách.</p>
                        }
                        else
                        {
                            <ul>
                                @foreach (var detail in ticket.Details)
                                {
                                    <li>
                                        @detail.BookTitle
                                        <span>SL: @detail.Quantity</span>
                                    </li>
                                }
                            </ul>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(ticket.Note))
                    {
                        <div class="ticket-note">
                            <strong>Ghi chú:</strong> @ticket.Note
                        </div>
                    }

                    <div class="ticket-actions">
                        @if (ticket.Status == "Pending")
                        {
                            <button class="btn btn-success"
                                    @onclick="() => ApproveBorrow(ticket.BorrowTicketId)">
                                ✅ Duyệt mượn
                            </button>

                            <button class="btn btn-danger"
                                    @onclick="() => RejectBorrow(ticket.BorrowTicketId)">
                                ❌ Từ chối
                            </button>
                        }

                        @if (ticket.Status == "Borrowing")
                        {
                            <button class="btn btn-warning"
                                    @onclick="() => ReturnBook(ticket.BorrowTicketId)">
                                📥 Xác nhận trả
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<BorrowHistoryModel> borrowTickets = new();
    private bool isLoading = true;
    private string? errorMessage;
    private string currentStatus = "Pending";
    public class ReturnResult
    {
        public string Message { get; set; } = "";
        public int OverdueDays { get; set; }
        public int FineAmount { get; set; }
    }

    private List<BorrowHistoryModel> FilteredTickets =>
        currentStatus == "All"
            ? borrowTickets
            : borrowTickets.Where(x => x.Status == currentStatus).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadBorrows();
    }

    private async Task SetToken()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

        if (!string.IsNullOrWhiteSpace(token))
        {
            Http.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task LoadBorrows()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            await SetToken();

            borrowTickets =
                await Http.GetFromJsonAsync<List<BorrowHistoryModel>>("api/Borrow/history")
                ?? new List<BorrowHistoryModel>();

            borrowTickets = borrowTickets
                .OrderByDescending(x => x.BorrowDate)
                .ToList();
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi tải dữ liệu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetStatus(string status)
    {
        currentStatus = status;
    }

    private async Task ApproveBorrow(int id)
    {
        await SetToken();

        var response = await Http.PutAsync($"api/Borrow/{id}/approve", null);

        if (response.IsSuccessStatusCode)
        {
            await LoadBorrows();
            errorMessage = null;
        }
        else
        {
            errorMessage = await response.Content.ReadAsStringAsync();
        }
    }

    private async Task RejectBorrow(int id)
    {
        await SetToken();

        var response = await Http.PutAsync($"api/Borrow/{id}/reject", null);

        if (response.IsSuccessStatusCode)
        {
            errorMessage = "✅ Đã từ chối yêu cầu mượn sách.";
            await LoadBorrows();
        }
        else
        {
            errorMessage = await response.Content.ReadAsStringAsync();
        }
    }

    private async Task ReturnBook(int id)
    {
        await SetToken();

        var response = await Http.PutAsync($"api/Borrow/{id}/return", null);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<ReturnResult>();

            if (result != null)
            {
                errorMessage =
                    $"✅ Trả sách thành công. Quá hạn: {result.OverdueDays} ngày. " +
                    $"Phí phạt: {result.FineAmount:N0} VNĐ.";
            }
            else
            {
                errorMessage = "✅ Trả sách thành công.";
            }

            await LoadBorrows();
        }
        else
        {
            errorMessage = await response.Content.ReadAsStringAsync();
        }
    }

    private string GetStatusText(string status)
    {
        return status switch
        {
            "Pending" => "Chờ duyệt",
            "Borrowing" => "Đang mượn",
            "Returned" => "Đã trả",
            "Rejected" => "Từ chối",
            _ => status
        };
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "Pending" => "status-pending",
            "Borrowing" => "status-borrowing",
            "Returned" => "status-returned",
            "Rejected" => "status-rejected",
            _ => "status-other"
        };
    }
}
