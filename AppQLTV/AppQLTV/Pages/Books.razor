@page "/books"
@using AppQLTV.Models
@using AppQLTV.Services
@inject IBookService BookService
@inject NavigationManager Navigation

<div class="container-fluid py-3">
    <!-- Header & Nút Thêm sách mới -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0 text-primary">
            📚 Danh sách sách
        </h3>
        <a href="/add-book" class="btn btn-success fw-bold px-4 py-2" style="border-radius: 0.75rem; box-shadow: 0 4px 6px rgba(16, 185, 129, 0.2);">
            + Thêm sách mới
        </a>
    </div>

    <!-- Thanh tìm kiếm -->
    <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
        <div class="card-body p-3">
            <div class="d-flex gap-2 align-items-center flex-wrap flex-md-nowrap">
                <div class="flex-grow-1">
                    <input type="text" class="form-control form-control-lg bg-light"
                           @bind="keyword" @bind:event="oninput"
                           placeholder="🔍 Tìm theo tên, tác giả, thể loại..."
                           style="border-radius: 0.75rem; border: 1px solid #e2e8f0;" />
                </div>

                <button class="btn btn-primary btn-lg px-4" @onclick="Search" style="border-radius: 0.75rem;">
                    Tìm
                </button>
                <button class="btn btn-secondary btn-lg px-4" @onclick="LoadBooks" style="border-radius: 0.75rem;">
                    🔄 Tải lại
                </button>
            </div>
        </div>
    </div>

    <!-- Danh sách Card -->
    @if (books == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-3 text-muted fw-medium">Đang tải dữ liệu sách...</p>
        </div>
    }
    else if (!books.Any())
    {
        <div class="alert alert-warning border-0 shadow-sm d-flex align-items-center" style="border-radius: 1rem;">
            ⚠️ <span class="ms-2">Không tìm thấy sách nào phù hợp. Bạn thử tìm từ khóa khác nhé!</span>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var book in books)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <!-- Thẻ Card được bo góc mềm mại và đổ bóng -->
                    <div class="card book-card h-100 border-0 shadow-sm" style="border-radius: 1.25rem; overflow: hidden; background: #ffffff;">

                        <!-- VÙNG ẢNH BÌA: Tăng chiều cao lên 280px cho giống sách thật -->
                        <!-- Sử dụng bg-light để lót nền phòng trường hợp ảnh bị lỗi -->
                        <div class="position-relative bg-light border-bottom" style="height: 280px; width: 100%;">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <!-- onerror giúp ẩn ngay cái icon "ảnh rách" xấu xí đi nếu đường dẫn ảnh bị sai -->
                                <img src="@book.ImageUrl" class="card-img-top book-img w-100 h-100" alt="@book.Title"
                                     style="object-fit: cover; color: transparent; background-color: #f1f5f9; text-align: center;"
                                     onerror="this.onerror=null; this.src='https://via.placeholder.com/300x400/e2e8f0/64748b?text=L%E1%BB%97i+%E1%BA%A3nh';">
                            }
                            else
                            {
                                <!-- Khung dự phòng khi không có link ảnh -->
                                <div class="d-flex flex-column align-items-center justify-content-center h-100 w-100 text-muted" style="background-color: #f8fafc;">
                                    <i class="bi bi-journal-album" style="font-size: 3.5rem; color: #cbd5e1;"></i>
                                </div>
                            }

                            <!-- Nhãn Thể loại góc trái -->
                            <span class="badge bg-primary position-absolute top-0 start-0 m-3 px-3 py-2 shadow-sm" style="border-radius: 0.5rem; font-size: 0.85rem; letter-spacing: 0.5px;">
                                @book.Category
                            </span>
                        </div>

                        <!-- NỘI DUNG SÁCH -->
                        <div class="card-body d-flex flex-column p-4">

                            <!-- Tiêu đề: Khống chế tối đa 2 dòng, nếu dài quá sẽ thành dấu 3 chấm. Giúp các card luôn bằng nhau -->
                            <h5 class="fw-bold text-dark mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; line-height: 1.4; min-height: 2.8rem;" title="@book.Title">
                                @book.Title
                            </h5>

                            <!-- Tác giả -->
                            <p class="text-muted mb-4 text-truncate" style="font-size: 0.95rem;">
                                <i class="bi bi-pen me-1"></i> @book.Author
                            </p>

                            <!-- Footer: Nút chi tiết và Tình trạng -->
                            <div class="mt-auto pt-3 border-top d-flex justify-content-between align-items-center">
                                <div class="d-flex flex-column">
                                    <small class="text-muted" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Tình trạng</small>
                                    <span class="fw-bold @(book.AvailableQuantity > 0 ? "text-success" : "text-danger")" style="font-size: 1.15rem;">
                                        Còn: @book.AvailableQuantity
                                    </span>
                                </div>

                                <a href="/book-detail/@book.BookId" class="btn btn-primary px-4 py-2 fw-bold" style="border-radius: 0.75rem; box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);">
                                    Chi tiết
                                </a>
                            </div>

                        </div>

                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Book> books = new();
    private string keyword = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        books = await BookService.GetBooksAsync();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(keyword))
            await LoadBooks();
        else
            books = await BookService.SearchBooksAsync(keyword);
    }
}