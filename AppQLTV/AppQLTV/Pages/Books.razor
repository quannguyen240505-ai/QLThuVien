@page "/books"
@using AppQLTV.Models
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Danh sách sách - Thư viện</PageTitle>

<div class="books-container">
    <h2 class="mb-4">📚 Danh sách sách trong thư viện</h2>

    @if (books == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Đang tải...</span>
            </div>
            <p>Đang tải dữ liệu...</p>
        </div>
    }
    else if (!books.Any())
    {
        <div class="alert alert-warning">Chưa có sách nào trong thư viện.</div>
    }
    else
    {
        <div class="books-grid">
            @foreach (var book in paginatedBooks)
            {
                <div class="book-card">
                    <div class="book-card-cover">
                        @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                        {
                            <img src="@book.CoverImageUrl" alt="@book.Title" class="book-cover-img" />
                        }
                        else
                        {
                            <div class="placeholder-cover">📖</div>
                        }
                    </div>
                    <div class="book-card-body">
                        <div class="book-title">@book.Title</div>
                        <div class="book-author">✍️ @book.Author</div>
                        <div class="book-meta">
                            <span class="book-category">@(string.IsNullOrEmpty(book.Category) ? "Chưa phân loại" : book.Category)</span>
                            <span class="book-year">@(book.PublishYear > 0 ? book.PublishYear.ToString() : "?")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(book.Description))
                        {
                            <div class="book-description">
                                @(book.Description.Length > 80 ? book.Description.Substring(0, 80) + "..." : book.Description)
                            </div>
                        }
                        <div class="book-stats">
                            <span class="book-available @(book.AvailableCopies > 0 ? "available" : "unavailable")">
                                @(book.AvailableCopies > 0 ? "✅ Còn sách" : "❌ Hết sách")
                            </span>
                            <span class="book-total">Còn @book.AvailableCopies / @book.TotalCopies</span>
                        </div>
                        <div class="card-actions">
                            <button class="btn-detail" @onclick="() => ViewDetail(book.Id)">Xem chi tiết</button>
                            <button class="btn-borrow" @onclick="() => BorrowBook(book.Id)">📖 Mượn sách</button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- PHÂN TRANG -->
        @if (totalPages > 1)
        {
            <div class="pagination-container">
                <nav aria-label="Page navigation">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(1)">Đầu</button>
                        </li>
                        <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage - 1)">Trước</button>
                        </li>
                        @for (int i = 1; i <= totalPages; i++)
                        {
                            var pageNum = i; // Quan trọng: lưu cục bộ để tránh closure
                            <li class="page-item @(currentPage == pageNum ? "active" : "")">
                                <button class="page-link" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                            </li>
                        }
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(currentPage + 1)">Sau</button>
                        </li>
                        <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                            <button class="page-link" @onclick="() => GoToPage(totalPages)">Cuối</button>
                        </li>
                    </ul>
                </nav>
                <div class="page-info text-center mt-2">
                    Hiển thị @((currentPage - 1) * pageSize + 1) - @(Math.Min(currentPage * pageSize, totalBooks)) trong tổng số @totalBooks sách
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Book>? books;
    private List<Book> paginatedBooks = new();
    private int currentPage = 1;
    private int pageSize = 8;
    private int totalPages = 0;
    private int totalBooks = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            books = await Http.GetFromJsonAsync<List<Book>>("api/books");
            if (books != null)
            {
                totalBooks = books.Count;
                totalPages = (int)Math.Ceiling((double)totalBooks / pageSize);
                UpdatePaginatedBooks();
            }
            else
            {
                books = new List<Book>();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi tải sách: {ex.Message}");
            books = new List<Book>();
        }
    }

    private void UpdatePaginatedBooks()
    {
        if (books == null) return;
        paginatedBooks = books
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
        StateHasChanged();
    }

    private async Task GoToPage(int page)
    {
        if (page < 1 || page > totalPages) return;
        currentPage = page;
        UpdatePaginatedBooks();
        await JS.InvokeVoidAsync("window.scrollTo", new { top = 0, behavior = "smooth" });
    }

    private void ViewDetail(int bookId)
    {
        Navigation.NavigateTo($"/book-detail/{bookId}");
    }

    private async Task BorrowBook(int bookId)
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (string.IsNullOrEmpty(token))
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "returnUrl", Navigation.Uri);
            await JS.InvokeVoidAsync("alert", "Vui lòng đăng nhập để mượn sách.");
            Navigation.NavigateTo("/login", true);
            return;
        }
        Navigation.NavigateTo($"/borrow-book?bookId={bookId}");
    }
}