@page "/books"
@using AppQLTV.Models
@using AppQLTV.Services
@inject IBookService BookService
@inject NavigationManager Navigation

<h3>📚 Danh sách sách</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <input type="text" class="form-control" @bind="keyword" @bind:event="oninput" placeholder="Tìm theo tên, tác giả, thể loại..." />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary" @onclick="Search">Tìm</button>
        <button class="btn btn-secondary ms-2" @onclick="LoadBooks">Tải lại</button>
    </div>
</div>

@if (books == null)
{
    <p>Đang tải...</p>
}
else if (!books.Any())
{
    <div class="alert alert-warning">Không có sách nào.</div>
}
else
{
    <div class="row">
        @foreach (var book in books)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm">
                    @if (!string.IsNullOrEmpty(book.ImageUrl))
                    {
                        <img src="@book.ImageUrl" class="card-img-top" alt="@book.Title" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                            <span class="text-muted">📖 No image</span>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@book.Title</h5>
                        <p class="card-text">
                            <strong>Tác giả:</strong> @book.Author<br />
                            <strong>Thể loại:</strong> @book.Category<br />
                            <strong>Còn lại:</strong> @book.AvailableQuantity
                        </p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0">
                        <a href="/book-detail/@book.BookId" class="btn btn-sm btn-info w-100">🔍 Xem chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Book> books = new();
    private string keyword = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        books = await BookService.GetBooksAsync();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(keyword))
            await LoadBooks();
        else
            books = await BookService.SearchBooksAsync(keyword);
    }
}