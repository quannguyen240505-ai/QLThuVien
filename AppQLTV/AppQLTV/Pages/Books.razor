@page "/books"
@using AppQLTV.Models
@using AppQLTV.Services
@inject IBookService BookService
@inject IJSRuntime js          // <-- THÊM DÒNG NÀY
@inject NavigationManager Navigation

<h3>📚 Danh sách sách</h3>

<div class="row mb-3">
    <div class="col-md-6">
        <input type="text" class="form-control" @bind="keyword" @bind:event="oninput" placeholder="Tìm theo tên, tác giả, thể loại..." />
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary" @onclick="Search">Tìm</button>
        <button class="btn btn-secondary ms-2" @onclick="LoadBooks">Tải lại</button>
    </div>
    <div class="col-md-4 text-end">
        <a href="/books/create" class="btn btn-success">+ Thêm sách mới</a>
    </div>
</div>

@if (books == null)
{
    <p>Đang tải...</p>
}
else if (!books.Any())
{
    <div class="alert alert-warning">Không có sách nào.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr><th>ID</th><th>Tiêu đề</th><th>Tác giả</th><th>Thể loại</th><th>Năm XB</th><th>Tổng số</th><th>Còn lại</th><th>Hành động</th></tr>
        </thead>
        <tbody>
            @foreach (var book in books)
            {
                <tr>
                    <td>@book.BookId</td>
                    <td>@book.Title</td>
                    <td>@book.Author</td>
                    <td>@book.Category</td>
                    <td>@book.PublishYear</td>
                    <td>@book.Quantity</td>
                    <td>@book.AvailableQuantity</td>
                    <td>
                        <a href="/books/edit/@book.BookId" class="btn btn-sm btn-warning">Sửa</a>
                        <button class="btn btn-sm btn-danger ms-1" @onclick="() => Delete(book.BookId)">Xóa</button>
                        <a href="/books/detail/@book.BookId" class="btn btn-sm btn-info ms-1">Chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Book> books = new();
    private string keyword = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadBooks();
    }

    private async Task LoadBooks()
    {
        books = await BookService.GetBooksAsync();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(keyword))
            await LoadBooks();
        else
            books = await BookService.SearchBooksAsync(keyword);
    }

    private async Task Delete(int id)
    {
        if (await js.InvokeAsync<bool>("confirm", "Bạn có chắc muốn xóa sách này?"))
        {
            await BookService.DeleteBookAsync(id);
            await LoadBooks();
        }
    }
}