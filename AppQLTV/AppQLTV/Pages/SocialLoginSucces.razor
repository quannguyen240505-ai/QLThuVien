@page "/social-login-success"
@using System.Net.Http.Json
@using AppQLTV.Models.Auth
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Đang đăng nhập...</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <div class="auth-icon">
                <i class="bi bi-google"></i>
            </div>

            <h1>Đang xử lý đăng nhập</h1>
            <p>Vui lòng chờ trong giây lát...</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert">
                @errorMessage
            </div>
        }
    </div>
</div>

@code {
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var error = query.Get("error");
        var code = query.Get("code");

        if (!string.IsNullOrWhiteSpace(error))
        {
            errorMessage = $"Đăng nhập Google thất bại: {error}";
            return;
        }

        if (string.IsNullOrWhiteSpace(code))
        {
            errorMessage = "Không nhận được mã đăng nhập từ máy chủ.";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync(
                "api/Auth/exchange-social-code",
                new ExchangeSocialCodeRequest
                {
                    Code = code
                }
            );

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();

                if (string.IsNullOrWhiteSpace(errorMessage))
                {
                    errorMessage = "Không thể hoàn tất đăng nhập Google.";
                }

                return;
            }

            var result = await response.Content.ReadFromJsonAsync<AuthResponse>();

            if (result == null || string.IsNullOrWhiteSpace(result.Token))
            {
                errorMessage = "Không nhận được token đăng nhập.";
                return;
            }

            await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
            await JS.InvokeVoidAsync("localStorage.setItem", "username", result.Username);
            await JS.InvokeVoidAsync("localStorage.setItem", "gmail", result.Gmail);
            await JS.InvokeVoidAsync("localStorage.setItem", "role", result.Role);
            await JS.InvokeVoidAsync("localStorage.setItem", "tokenExpiration", result.Expiration.ToString("O"));

            Navigation.NavigateTo("/", forceLoad: true);
        }
        catch
        {
            errorMessage = "Không thể kết nối đến máy chủ API.";
        }
    }
}