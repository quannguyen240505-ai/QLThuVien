@page "/borrow-book"
@using System.Net.Http.Json
@using AppQLTV.Models.Library
@inject HttpClient Http

<PageTitle>Gửi yêu cầu mượn sách</PageTitle>

<div class="borrow-page">
    <div class="borrow-header">
        <h2>📚 Gửi yêu cầu mượn sách</h2>
        <p>Chọn độc giả và sách từ danh sách có sẵn</p>
    </div>

    @if (!string.IsNullOrWhiteSpace(message))
    {
        <div class="alert alert-info">@message</div>
    }

    <div class="borrow-card">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label>Độc giả</label>
                <select class="form-control" @bind="borrow.ReaderId">
                    <option value="0">-- Chọn độc giả --</option>
                    @foreach (var reader in readers)
                    {
                        <option value="@reader.ReaderId">
                            @reader.FullName - @reader.Phone
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-6 mb-3">
                <label>Ngày hẹn trả</label>
                <input class="form-control"
                       type="date"
                       min="@DateTime.Now.ToString("yyyy-MM-dd")"
                       max="@DateTime.Now.AddDays(14).ToString("yyyy-MM-dd")"
                       @bind="borrow.DueDate" />
            </div>

            <div class="col-md-8 mb-3">
                <label>Sách</label>
                <select class="form-control" @bind="bookItem.BookId">
                    <option value="0">-- Chọn sách --</option>
                    @foreach (var book in books)
                    {
                        <option value="@book.Id">
                            @book.Title - còn @book.AvailableCopies cuốn
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4 mb-3">
                <label>Số lượng</label>
                <input class="form-control"
                       type="number"
                       min="1"
                       max="5"
                       @bind="bookItem.Quantity" />
            </div>

            <div class="col-12 mb-3">
                <button class="btn btn-secondary" @onclick="AddBook">
                    + Thêm sách vào yêu cầu
                </button>
            </div>

            <div class="col-12 mb-3">
                <label>Ghi chú</label>
                <textarea class="form-control" rows="3" @bind="borrow.Note"></textarea>
            </div>
        </div>

        @if (borrow.Books.Count > 0)
        {
            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Tên sách</th>
                        <th>Số lượng</th>
                        <th>Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in borrow.Books)
                    {
                        var book = books.FirstOrDefault(x => x.Id == item.BookId);

                        <tr>
                            <td>@book?.Title</td>
                            <td>@item.Quantity</td>
                            <td>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => RemoveBook(item)">
                                    Xóa
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <div class="borrow-actions">
            <button class="btn btn-primary" @onclick="SendBorrowRequest">
                Gửi yêu cầu mượn sách
            </button>

            <button class="btn btn-outline-secondary" @onclick="ResetForm">
                Làm mới
            </button>
        </div>
    </div>
</div>

@code {
    private List<ReaderModel> readers = new();
    private List<BookModel> books = new();

    private BorrowRequest borrow = new()
    {
        DueDate = DateTime.Now.AddDays(7)
    };

    private BorrowBookItem bookItem = new()
    {
        Quantity = 1
    };

    private string message = "";

    protected override async Task OnInitializedAsync()
    {
        readers = await Http.GetFromJsonAsync<List<ReaderModel>>("api/readers") ?? new();
        books = await Http.GetFromJsonAsync<List<BookModel>>("api/books") ?? new();
    }

    private void AddBook()
    {
        if (borrow.ReaderId <= 0)
        {
            message = "Vui lòng chọn độc giả.";
            return;
        }

        if (bookItem.BookId <= 0)
        {
            message = "Vui lòng chọn sách.";
            return;
        }

        if (bookItem.Quantity <= 0)
        {
            message = "Số lượng phải lớn hơn 0.";
            return;
        }

        var totalQuantity = borrow.Books.Sum(x => x.Quantity) + bookItem.Quantity;

        if (totalQuantity > 5)
        {
            message = "Mỗi lần chỉ được mượn tối đa 5 quyển sách.";
            return;
        }

        var book = books.FirstOrDefault(x => x.Id == bookItem.BookId);

        if (book == null)
        {
            message = "Sách không tồn tại.";
            return;
        }

        if (book.AvailableCopies < bookItem.Quantity)
        {
            message = $"Sách {book.Title} không đủ số lượng.";
            return;
        }

        borrow.Books.Add(new BorrowBookItem
        {
            BookId = bookItem.BookId,
            Quantity = bookItem.Quantity
        });

        bookItem = new BorrowBookItem
        {
            Quantity = 1
        };

        message = "";
    }

    private void RemoveBook(BorrowBookItem item)
    {
        borrow.Books.Remove(item);
    }

    private async Task SendBorrowRequest()
    {
        if (borrow.ReaderId <= 0)
        {
            message = "Vui lòng chọn độc giả.";
            return;
        }

        if (borrow.Books.Count == 0)
        {
            message = "Vui lòng thêm ít nhất một sách.";
            return;
        }

        if (borrow.DueDate.Date > DateTime.Now.Date.AddDays(14))
        {
            message = "Số ngày mượn tối đa là 14 ngày.";
            return;
        }

        var response = await Http.PostAsJsonAsync("api/Borrow/request", borrow);

        if (response.IsSuccessStatusCode)
        {
            message = "Gửi yêu cầu mượn sách thành công. Vui lòng chờ duyệt.";
            ResetForm();
        }
        else
        {
            message = await response.Content.ReadAsStringAsync();
        }
    }

    private void ResetForm()
    {
        borrow = new BorrowRequest
        {
            DueDate = DateTime.Now.AddDays(7)
        };

        bookItem = new BorrowBookItem
        {
            Quantity = 1
        };
    }
}