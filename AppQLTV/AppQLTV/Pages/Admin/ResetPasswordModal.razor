@using System.Net.Http
@using System.Net.Http.Json
@using AppQLTV.Models.Admin

<div class="modal-backdrop-custom">
    <div class="admin-modal small">
        <div class="modal-header-custom">
            <div>
                <h2>Reset mật khẩu</h2>
                <p>Đặt lại mật khẩu cho tài khoản <strong>@SelectedUser?.Username</strong>.</p>
            </div>

            <button class="modal-close" @onclick="OnClose">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <EditForm Model="Model" OnValidSubmit="OnSubmit">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Mật khẩu mới</label>
                <InputText class="form-control"
                           type="password"
                           @bind-Value="Model.NewPassword"
                           placeholder="Nhập mật khẩu mới" />
                <ValidationMessage For="@(() => Model.NewPassword)" />
            </div>

            <div class="modal-actions">
                <button type="button" class="admin-secondary-btn" @onclick="OnClose">Hủy</button>

                <button type="submit" class="admin-primary-btn" disabled="@IsSubmitting">
                    @(IsSubmitting ? "Đang reset..." : "Reset mật khẩu")
                </button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public UserResponse? SelectedUser { get; set; }

    [Parameter] public AdminResetUserPasswordRequest Model { get; set; } = new();

    [Parameter] public bool IsSubmitting { get; set; }

    [Parameter] public EventCallback OnSubmit { get; set; }

    [Parameter] public EventCallback OnClose { get; set; }
}