@page "/statistics"
@using global::System.Net.Http.Headers
@using AppQLTV.Models.Admin
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Thống kê hoạt động</PageTitle>

<section class="statistics-page">

    <div class="statistics-header">
        <div>
            <span class="statistics-label">
                <i class="bi bi-bar-chart"></i>
                Admin Dashboard
            </span>

            <h1>Thống kê hoạt động</h1>
            <p>Theo dõi tổng quan tài khoản, phân quyền và cấu hình vận hành hiện tại của thư viện.</p>
        </div>

        <button class="statistics-refresh-btn" @onclick="LoadStatistics">
            <i class="bi bi-arrow-clockwise"></i>
            Tải lại
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="statistics-alert">
            @errorMessage
        </div>
    }

    @if (isLoading)
    {
        <div class="statistics-loading">
            <i class="bi bi-arrow-repeat"></i>
            Đang tải dữ liệu thống kê...
        </div>
    }
    else
    {
        <div class="stats-grid">

            <div class="stat-card primary">
                <div class="stat-icon">
                    <i class="bi bi-people"></i>
                </div>
                <div>
                    <span>Tổng tài khoản</span>
                    <strong>@statistics.TotalUsers</strong>
                </div>
            </div>

            <div class="stat-card success">
                <div class="stat-icon">
                    <i class="bi bi-person-check"></i>
                </div>
                <div>
                    <span>Đang hoạt động</span>
                    <strong>@statistics.TotalActiveUsers</strong>
                </div>
            </div>

            <div class="stat-card danger">
                <div class="stat-icon">
                    <i class="bi bi-person-lock"></i>
                </div>
                <div>
                    <span>Bị khóa</span>
                    <strong>@statistics.TotalLockedUsers</strong>
                </div>
            </div>

            <div class="stat-card warning">
                <div class="stat-icon">
                    <i class="bi bi-google"></i>
                </div>
                <div>
                    <span>Tài khoản Google</span>
                    <strong>@statistics.TotalGoogleAccounts</strong>
                </div>
            </div>

        </div>

        <div class="statistics-layout">

            <div class="statistics-card">
                <div class="card-title">
                    <i class="bi bi-shield-lock"></i>
                    <div>
                        <h2>Phân bố vai trò</h2>
                        <p>Số lượng tài khoản theo từng role trong hệ thống.</p>
                    </div>
                </div>

                <div class="role-list">
                    <div class="role-row">
                        <span>Member</span>
                        <strong>@statistics.TotalMembers</strong>
                    </div>

                    <div class="role-row">
                        <span>Librarian</span>
                        <strong>@statistics.TotalLibrarians</strong>
                    </div>

                    <div class="role-row">
                        <span>Admin</span>
                        <strong>@statistics.TotalAdmins</strong>
                    </div>
                </div>
            </div>

            <div class="statistics-card">
                <div class="card-title">
                    <i class="bi bi-key"></i>
                    <div>
                        <h2>Loại tài khoản</h2>
                        <p>Thống kê theo phương thức đăng nhập.</p>
                    </div>
                </div>

                <div class="role-list">
                    <div class="role-row">
                        <span>Local</span>
                        <strong>@statistics.TotalLocalAccounts</strong>
                    </div>

                    <div class="role-row">
                        <span>Google</span>
                        <strong>@statistics.TotalGoogleAccounts</strong>
                    </div>
                </div>
            </div>

        </div>

        <div class="statistics-card system-overview">
            <div class="card-title">
                <i class="bi bi-sliders"></i>
                <div>
                    <h2>Cấu hình vận hành hiện tại</h2>
                    <p>Các quy định này được Admin cấu hình trong mục Quản lý hệ thống.</p>
                </div>
            </div>

            <div class="system-policy-grid">
                <div class="policy-item">
                    <span>Tên thư viện</span>
                    <strong>@statistics.LibraryName</strong>
                </div>

                <div class="policy-item">
                    <span>Trạng thái yêu cầu mượn</span>
                    <strong class="@(statistics.AllowBorrowRequest ? "text-success" : "text-danger")">
                        @(statistics.AllowBorrowRequest ? "Đang mở" : "Đang tắt")
                    </strong>
                </div>

                <div class="policy-item">
                    <span>Số sách tối đa</span>
                    <strong>@statistics.MaxBorrowBooks quyển</strong>
                </div>

                <div class="policy-item">
                    <span>Số ngày mượn tối đa</span>
                    <strong>@statistics.MaxBorrowDays ngày</strong>
                </div>

                <div class="policy-item">
                    <span>Phí phạt/ngày</span>
                    <strong>@statistics.OverdueFinePerDay.ToString("N0") VNĐ</strong>
                </div>

                <div class="policy-item">
                    <span>Cập nhật cấu hình</span>
                    <strong>@statistics.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                </div>
            </div>
        </div>
    }

</section>

@code {
    private ActivityStatisticsResponse statistics = new();

    private bool isLoading = true;

    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadStatistics();
    }

    private async Task LoadStatistics()
    {
        isLoading = true;
        errorMessage = "";

        try
        {
            var request = await CreateAuthorizedRequest(HttpMethod.Get, "api/Statistics/activity");
            var response = await Http.SendAsync(request);

            if (response.StatusCode == global::System.Net.HttpStatusCode.Unauthorized)
            {
                Navigation.NavigateTo("/login", forceLoad: true);
                return;
            }

            if (response.StatusCode == global::System.Net.HttpStatusCode.Forbidden)
            {
                errorMessage = "Bạn không có quyền truy cập chức năng thống kê.";
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<ActivityStatisticsResponse>();

            if (result == null)
            {
                errorMessage = "Không đọc được dữ liệu thống kê.";
                return;
            }

            statistics = result;
        }
        catch
        {
            errorMessage = "Không thể kết nối đến máy chủ API.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<HttpRequestMessage> CreateAuthorizedRequest(HttpMethod method, string url)
    {
        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");

        var request = new HttpRequestMessage(method, url);

        if (!string.IsNullOrWhiteSpace(token))
        {
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }

        return request;
    }
}