@page "/reset-password"
@using System.Net.Http.Json
@using AppQLTV.Models.Auth
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Đặt lại mật khẩu</PageTitle>

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-header">
            <div class="auth-icon">
                <i class="bi bi-shield-lock"></i>
            </div>

            <h1>Đặt lại mật khẩu</h1>
            <p>Nhập mã PIN đã gửi về Gmail và tạo mật khẩu mới.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="auth-success">
                @successMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert">
                @errorMessage
            </div>
        }

        <EditForm Model="resetModel" OnValidSubmit="HandleResetPassword">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Gmail</label>
                <InputText class="form-control"
                           @bind-Value="resetModel.Gmail"
                           placeholder="Nhập Gmail của bạn" />
                <ValidationMessage For="@(() => resetModel.Gmail)" />
            </div>

            <div class="form-group">
                <label>Mã PIN</label>
                <InputText class="form-control pin-input"
                           @bind-Value="resetModel.Pin"
                           maxlength="6"
                           placeholder="Nhập mã PIN 6 số" />
                <ValidationMessage For="@(() => resetModel.Pin)" />
            </div>

            <div class="form-group">
                <label>Mật khẩu mới</label>
                <InputText class="form-control"
                           type="password"
                           @bind-Value="resetModel.NewPassword"
                           placeholder="Nhập mật khẩu mới" />
                <ValidationMessage For="@(() => resetModel.NewPassword)" />
            </div>

            <div class="form-group">
                <label>Xác nhận mật khẩu mới</label>
                <InputText class="form-control"
                           type="password"
                           @bind-Value="resetModel.ConfirmNewPassword"
                           placeholder="Nhập lại mật khẩu mới" />
                <ValidationMessage For="@(() => resetModel.ConfirmNewPassword)" />
            </div>

            <button class="auth-submit" type="submit" disabled="@isLoading">
                @(isLoading ? "Đang đặt lại..." : "Đặt lại mật khẩu")
            </button>
        </EditForm>

        <div class="auth-footer">
            Chưa nhận được mã?
            <a href="forgot-password">Gửi lại mã PIN</a>
        </div>

    </div>
</div>

@code {
    private ResetPasswordRequest resetModel = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);

        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var gmail = query.Get("gmail");

        if (!string.IsNullOrWhiteSpace(gmail))
        {
            resetModel.Gmail = gmail;
        }
    }

    private async Task HandleResetPassword()
    {
        isLoading = true;
        errorMessage = "";
        successMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/reset-password", resetModel);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();

                if (string.IsNullOrWhiteSpace(errorMessage))
                {
                    errorMessage = "Đặt lại mật khẩu thất bại.";
                }

                return;
            }

            successMessage = "Đặt lại mật khẩu thành công. Vui lòng đăng nhập lại.";

            await Task.Delay(1200);

            Navigation.NavigateTo("/login");
        }
        catch
        {
            errorMessage = "Không thể kết nối đến máy chủ API.";
        }
        finally
        {
            isLoading = false;
        }
    }
}