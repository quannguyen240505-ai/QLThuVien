@page "/forgot-password"
@using System.Net.Http.Json
@using AppQLTV.Models.Auth
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Quên mật khẩu</PageTitle>

<div class="auth-page">
    <div class="auth-card">

        <div class="auth-header">
            <div class="auth-icon">
                <i class="bi bi-envelope-lock"></i>
            </div>

            <h1>Quên mật khẩu</h1>
            <p>Nhập Gmail đã đăng ký để nhận mã PIN đặt lại mật khẩu.</p>
        </div>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="auth-success">
                @successMessage
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert">
                @errorMessage
            </div>
        }

        <EditForm Model="forgotModel" OnValidSubmit="HandleForgotPassword">
            <DataAnnotationsValidator />

            <div class="form-group">
                <label>Gmail</label>
                <InputText class="form-control"
                           @bind-Value="forgotModel.Gmail"
                           placeholder="Nhập Gmail của bạn" />
                <ValidationMessage For="@(() => forgotModel.Gmail)" />
            </div>

            <button class="auth-submit" type="submit" disabled="@isLoading">
                @(isLoading ? "Đang gửi mã PIN..." : "Gửi mã PIN")
            </button>
        </EditForm>

        <div class="auth-footer">
            Đã nhớ mật khẩu?
            <a href="login">Đăng nhập</a>
        </div>

    </div>
</div>

@code {
    private ForgotPasswordRequest forgotModel = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool isLoading = false;

    private async Task HandleForgotPassword()
    {
        isLoading = true;
        errorMessage = "";
        successMessage = "";

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/forgot-password", forgotModel);

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = await response.Content.ReadAsStringAsync();

                if (string.IsNullOrWhiteSpace(errorMessage))
                {
                    errorMessage = "Gửi mã PIN thất bại. Vui lòng kiểm tra lại Gmail.";
                }

                return;
            }

            successMessage = "Mã PIN đã được gửi về Gmail của bạn.";

            await Task.Delay(900);

            Navigation.NavigateTo($"/reset-password?gmail={Uri.EscapeDataString(forgotModel.Gmail)}");
        }
        catch
        {
            errorMessage = "Không thể kết nối đến máy chủ API.";
        }
        finally
        {
            isLoading = false;
        }
    }
}