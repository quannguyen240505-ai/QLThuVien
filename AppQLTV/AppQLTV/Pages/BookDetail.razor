@page "/book-detail/{id:int}"
@page "/book-detail"
@using AppQLTV.Models
@using System.Net.Http.Headers
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Chi tiết sách - Thư viện</PageTitle>

<div class="book-detail-container">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"></div>
            <p class="mt-3 text-muted">Đang tải thông tin sách...</p>
        </div>
    }
    else if (noIdProvided)
    {
        <div class="alert alert-info shadow-sm rounded-4 p-5 text-center" style="border-left: 5px solid #0dcaf0;">
            <i class="bi bi-info-circle" style="font-size: 4rem;"></i>
            <h3 class="mt-3">📖 Chưa có sách nào được chọn</h3>
            <p class="mb-4">Vui lòng chọn một quyển sách từ trang <strong>Danh sách sách</strong> để xem thông tin chi tiết.</p>
            <button class="btn btn-primary btn-lg px-4 rounded-pill" @onclick="GoToBooks">
                <i class="bi bi-book"></i> Đến danh sách sách
            </button>
        </div>
    }
    else if (showNotFound)
    {
        <div class="alert alert-warning shadow-sm rounded-4 p-5 text-center" style="border-left: 5px solid #ffc107;">
            <i class="bi bi-emoji-frown" style="font-size: 4rem;"></i>
            <h3 class="mt-3">Không tìm thấy sách</h3>
            <p class="mb-4">Sách bạn yêu cầu không tồn tại hoặc đã bị xóa khỏi thư viện.</p>
            <button class="btn btn-primary btn-lg px-4 rounded-pill" @onclick="GoBack">
                <i class="bi bi-arrow-left"></i> Quay lại danh sách
            </button>
        </div>
    }
    else if (book != null)
    {
        <div class="row g-4">
            <!-- Cột ảnh bìa -->
            <div class="col-md-5 col-lg-4">
                <div class="book-cover-card">
                    <div class="book-cover-placeholder">
                        @if (!string.IsNullOrEmpty(book.CoverImageUrl))
                        {
                            <img src="@book.CoverImageUrl" alt="@book.Title" class="detail-cover-img" />
                        }
                        else
                        {
                            <i class="bi bi-journal-bookmark-fill"></i>
                        }
                    </div>
                    <div class="mt-3 text-center">
                        @if (book.AvailableCopies > 0)
                        {
                            <span class="badge bg-success px-3 py-2 rounded-pill">
                                <i class="bi bi-check-circle"></i> Sẵn sàng cho mượn
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-3 py-2 rounded-pill">
                                <i class="bi bi-x-circle"></i> Đã được mượn hết
                            </span>
                        }
                    </div>
                </div>
            </div>

            <!-- Cột thông tin chi tiết -->
            <div class="col-md-7 col-lg-8">
                <div class="book-info-card">
                    <div class="d-flex flex-wrap justify-content-between align-items-start mb-3">
                        <span class="badge bg-primary px-3 py-2 rounded-pill">@(book.Category ?? "Chưa phân loại")</span>
                        <span class="text-muted"><i class="bi bi-upc-scan"></i> Mã sách: #@book.Id</span>
                    </div>
                    <h1 class="book-title">@book.Title</h1>
                    <h4 class="book-author">
                        <i class="bi bi-pencil"></i> @book.Author
                    </h4>

                    <hr class="my-4" />

                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <div class="info-item">
                                <div class="info-label"><i class="bi bi-building"></i> Nhà xuất bản</div>
                                <div class="info-value">@(book.Publisher ?? "Chưa có")</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="info-item">
                                <div class="info-label"><i class="bi bi-calendar"></i> Năm xuất bản</div>
                                <div class="info-value">@(book.PublishYear > 0 ? book.PublishYear.ToString() : "Không rõ")</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="info-item">
                                <div class="info-label"><i class="bi bi-upc-scan"></i> ISBN</div>
                                <div class="info-value">@(book.ISBN ?? "Chưa có")</div>
                            </div>
                        </div>
                        <div class="col-sm-6">
                            <div class="info-item">
                                <div class="info-label"><i class="bi bi-stack"></i> Số lượng</div>
                                <div class="info-value">
                                    <span class="fw-bold">@book.TotalCopies</span> cuốn
                                    <span class="text-muted">(còn <strong class="@(book.AvailableCopies > 0 ? "text-success" : "text-danger")">@book.AvailableCopies</strong>)</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="book-description">
                        <h5><i class="bi bi-journal-text"></i> Mô tả nội dung</h5>
                        <p>@(string.IsNullOrEmpty(book.Description) ? "Chưa có mô tả cho sách này." : book.Description)</p>
                    </div>

                    <div class="mt-4 d-flex gap-3">
                        <button class="btn btn-outline-secondary rounded-pill px-4" @onclick="GoBack">
                            <i class="bi bi-arrow-left"></i> Quay lại danh sách
                        </button>
                        <button class="btn btn-primary rounded-pill px-4 @(book.AvailableCopies <= 0 ? "disabled" : "")"
                                @onclick="BorrowBook">
                            <i class="bi bi-journal-plus"></i> Mượn sách
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Phần đánh giá & bình luận -->
        <div class="reviews-section mt-5">
            <h4>📝 Đánh giá & Bình luận</h4>

            @if (isLoggedIn)
            {
                <div class="card p-3 mb-4">
                    <div class="form-group mb-2">
                        <label>Đánh giá của bạn (1-5 sao)</label>
                        <select class="form-control" @bind="newRating">
                            <option value="5">⭐⭐⭐⭐⭐ 5 sao</option>
                            <option value="4">⭐⭐⭐⭐ 4 sao</option>
                            <option value="3">⭐⭐⭐ 3 sao</option>
                            <option value="2">⭐⭐ 2 sao</option>
                            <option value="1">⭐ 1 sao</option>
                        </select>
                    </div>
                    <div class="form-group mb-2">
                        <label>Bình luận</label>
                        <textarea class="form-control" rows="3" @bind="newComment" placeholder="Chia sẻ cảm nhận của bạn về cuốn sách..."></textarea>
                    </div>
                    <button class="btn btn-primary" @onclick="SubmitReview" disabled="@isSubmitting">
                        @(isSubmitting ? "Đang gửi..." : "Gửi đánh giá")
                    </button>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <a href="/login">Đăng nhập</a> để đánh giá và bình luận về sách.
                </div>
            }

            @if (reviews == null)
            {
                <div class="text-center">Đang tải bình luận...</div>
            }
            else if (!reviews.Any())
            {
                <div class="text-muted">Chưa có bình luận nào. Hãy là người đầu tiên bình luận!</div>
            }
            else
            {
                <div class="reviews-list">
                    @foreach (var review in reviews)
                    {
                        <div class="review-card card p-3 mb-3">
                            <div class="d-flex justify-content-between">
                                <strong>@review.UserName</strong>
                                <span class="text-muted">@review.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                            </div>
                            <div class="rating">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= review.Rating)
                                    {
                                        <span class="text-warning">★</span>
                                    }
                                    else
                                    {
                                        <span class="text-secondary">☆</span>
                                    }
                                }
                            </div>
                            <p class="mt-2">@review.Comment</p>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public int? id { get; set; }
    private Book? book;
    private bool isLoading = true;
    private bool showNotFound = false;
    private bool noIdProvided = false;

    // Biến cho phần bình luận
    private List<BookReview> reviews = new();
    private string newComment = "";
    private int newRating = 5;
    private bool isSubmitting = false;
    private bool isLoggedIn = false;

    protected override async Task OnInitializedAsync()
    {
        if (id == null || id <= 0)
        {
            noIdProvided = true;
            isLoading = false;
            return;
        }

        try
        {
            book = await Http.GetFromJsonAsync<Book>($"api/books/{id}");
            if (book == null) showNotFound = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi tải sách: {ex.Message}");
            showNotFound = true;
        }
        finally
        {
            isLoading = false;
        }

        await CheckLogin();
        await LoadReviews();
    }

    private async Task SetAuthorizationHeader()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
        }
    }

    private async Task CheckLogin()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        isLoggedIn = !string.IsNullOrEmpty(token);
    }

    private async Task LoadReviews()
    {
        if (id == null || id <= 0) return;
        try
        {
            reviews = await Http.GetFromJsonAsync<List<BookReview>>($"api/BookReviews/book/{id}") ?? new();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Lỗi tải bình luận: {ex.Message}");
        }
    }

    private async Task SubmitReview()
    {
        if (string.IsNullOrWhiteSpace(newComment))
        {
            await JS.InvokeVoidAsync("alert", "Vui lòng nhập nội dung bình luận.");
            return;
        }

        isSubmitting = true;
        try
        {
            await SetAuthorizationHeader();

            var request = new { BookId = id, Comment = newComment, Rating = newRating };
            var response = await Http.PostAsJsonAsync("api/BookReviews", request);
            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "Cảm ơn bạn đã đánh giá!");
                newComment = "";
                newRating = 5;
                await LoadReviews(); // tải lại danh sách
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"Lỗi: {error}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Lỗi kết nối: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/books");
    }

    private void GoToBooks()
    {
        Navigation.NavigateTo("/books");
    }

    private async Task BorrowBook()
    {
        var loggedIn = await IsUserLoggedIn();
        if (!loggedIn)
        {
            await JS.InvokeVoidAsync("localStorage.setItem", "returnUrl", Navigation.Uri);
            await JS.InvokeVoidAsync("alert", "Vui lòng đăng nhập để mượn sách.");
            Navigation.NavigateTo("/login", true);
            return;
        }

        if (book?.AvailableCopies <= 0)
        {
            await JS.InvokeVoidAsync("alert", "Sách này hiện không có sẵn để mượn.");
            return;
        }

        // Chuyển đến trang mượn sách (nếu có)
        Navigation.NavigateTo($"/borrow-book?bookId={book!.Id}");
    }

    private async Task<bool> IsUserLoggedIn()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            return !string.IsNullOrEmpty(token);
        }
        catch
        {
            return false;
        }
    }

    // Model BookReview cho frontend (nên đặt trong Models riêng)
    public class BookReview
    {
        public int ReviewId { get; set; }
        public int BookId { get; set; }
        public string Comment { get; set; } = string.Empty;
        public int Rating { get; set; }
        public DateTime CreatedAt { get; set; }
        public string UserName { get; set; } = string.Empty;
    }
}