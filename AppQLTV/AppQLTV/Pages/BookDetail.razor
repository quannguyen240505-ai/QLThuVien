@page "/book-detail/{id:int}"
@using AppQLTV.Models
@using AppQLTV.Services
@inject IBookService BookService
@inject NavigationManager Navigation

@if (book == null)
{
    <div class="d-flex justify-content-center align-items-center" style="height: 50vh;">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ms-3 text-muted fw-medium">Đang tải thông tin sách...</span>
    </div>
}
else
{
    <div class="container-fluid py-4">

        <!-- Nút Quay lại -->
        <button class="btn btn-light mb-4 text-secondary fw-bold px-4 py-2" style="border-radius: 0.75rem; border: 1px solid #e2e8f0;" @onclick='() => Navigation.NavigateTo("/books")'>
            <i class="bi bi-arrow-left me-2"></i> Quay lại danh sách
        </button>

        <!-- Thẻ chứa nội dung chi tiết dạng Card -->
        <div class="card border-0 shadow-sm" style="border-radius: 1.5rem; overflow: hidden; background: #ffffff;">
            <div class="card-body p-4 p-md-5">
                <div class="row g-5">

                    <!-- CỘT TRÁI: ẢNH BÌA SÁCH -->
                    <div class="col-12 col-md-4 col-lg-3 text-center">
                        <div class="position-relative shadow" style="border-radius: 1rem; overflow: hidden; aspect-ratio: 2/3; background-color: #f8fafc; border: 1px solid #e2e8f0;">
                            @if (!string.IsNullOrEmpty(book.ImageUrl))
                            {
                                <!-- Ẩn ảnh lỗi bằng onerror -->
                                <img src="@book.ImageUrl" alt="@book.Title" class="w-100 h-100" style="object-fit: cover;" onerror="this.onerror=null; this.src='https://via.placeholder.com/400x600/e2e8f0/64748b?text=Ch%C6%B0a+c%C3%B3+%E1%BA%A3nh';">
                            }
                            else
                            {
                                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                                    <i class="bi bi-journal-text" style="font-size: 5rem; color: #cbd5e1;"></i>
                                    <span class="mt-3 fw-medium">Chưa có bìa sách</span>
                                </div>
                            }
                        </div>

                        <!-- Hiển thị Trạng thái ngay dưới ảnh -->
                        <div class="mt-4">
                            @if (book.AvailableQuantity > 0)
                            {
                                <div class="badge bg-success-subtle text-success w-100 py-3 rounded-3" style="font-size: 1rem; border: 1px solid currentColor;">
                                    <i class="bi bi-check-circle-fill me-2"></i> Sẵn sàng cho mượn
                                </div>
                            }
                            else
                            {
                                <div class="badge bg-danger-subtle text-danger w-100 py-3 rounded-3" style="font-size: 1rem; border: 1px solid currentColor;">
                                    <i class="bi bi-x-circle-fill me-2"></i> Đã được mượn hết
                                </div>
                            }
                        </div>
                    </div>

                    <!-- CỘT PHẢI: THÔNG TIN CHI TIẾT -->
                    <div class="col-12 col-md-8 col-lg-9">

                        <!-- Header Thông tin (Title, Tác giả, Badge) -->
                        <div class="mb-4">
                            <span class="badge bg-primary px-3 py-2 mb-3 shadow-sm" style="border-radius: 0.5rem; letter-spacing: 0.5px;">
                                @book.Category
                            </span>
                            <h1 class="fw-bold text-dark mb-2">@book.Title</h1>
                            <h4 class="text-muted"><i class="bi bi-pen me-2"></i>@book.Author</h4>
                        </div>

                        <hr class="my-4" style="border-color: #e2e8f0;">

                        <!-- Bảng siêu liệu (Metadata) thiết kế dạng Grid Card -->
                        <div class="bg-light p-4 rounded-4 mb-4" style="border: 1px solid #f1f5f9;">
                            <h6 class="fw-bold text-primary mb-3 text-uppercase" style="letter-spacing: 1px;">Thông tin xuất bản</h6>
                            <div class="row g-3">
                                <div class="col-sm-6 col-md-4">
                                    <span class="text-muted d-block" style="font-size: 0.85rem;">Mã sách</span>
                                    <strong class="text-dark">#@book.BookId</strong>
                                </div>
                                <div class="col-sm-6 col-md-4">
                                    <span class="text-muted d-block" style="font-size: 0.85rem;">Nhà xuất bản</span>
                                    <strong class="text-dark">@book.Publisher</strong>
                                </div>
                                <div class="col-sm-6 col-md-4">
                                    <span class="text-muted d-block" style="font-size: 0.85rem;">Năm xuất bản</span>
                                    <strong class="text-dark">@book.PublishYear</strong>
                                </div>
                                <div class="col-sm-6 col-md-4">
                                    <span class="text-muted d-block" style="font-size: 0.85rem;">Tổng số lượng</span>
                                    <strong class="text-dark">@book.Quantity cuốn</strong>
                                </div>
                                <div class="col-sm-6 col-md-4">
                                    <span class="text-muted d-block" style="font-size: 0.85rem;">Còn lại trong kho</span>
                                    <strong class="@(book.AvailableQuantity > 0 ? "text-success" : "text-danger")">@book.AvailableQuantity cuốn</strong>
                                </div>
                            </div>
                        </div>

                        <!-- Phần Mô tả -->
                        <div class="mt-4">
                            <h6 class="fw-bold text-dark mb-3">Mô tả nội dung</h6>
                            <p class="text-muted" style="line-height: 1.8; font-size: 1.05rem;">
                                @if (!string.IsNullOrEmpty(book.Description))
                                {
                                    @book.Description
                                }
                                else
                                {
                                    <span class="fst-italic text-black-50">Sách này chưa có lời giới thiệu mô tả.</span>
                                }
                            </p>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int id { get; set; }
    private Book? book;

    protected override async Task OnInitializedAsync()
    {
        book = await BookService.GetBookByIdAsync(id);
    }
}