@inject IJSRuntime JS
@inject NavigationManager Navigation

<div class="sidebar-card @(IsCollapsed ? "collapsed" : "")">

    <div class="sidebar-header">
        <div class="brand">
            <div class="brand-icon">
                <i class="bi bi-book-half"></i>
            </div>

            <div class="brand-text">
                <div class="brand-name">QNU-LIBRARY</div>
                <div class="brand-subtitle">Library System</div>
            </div>
        </div>

        <button class="collapse-btn" @onclick="ToggleSidebar">
            <i class="bi @(IsCollapsed ? "bi-chevron-right" : "bi-chevron-left")"></i>
        </button>
    </div>

    <div class="search-box">
        <i class="bi bi-search"></i>
        <input placeholder="Tìm kiếm..." />
    </div>

    <nav class="menu">

        <div class="menu-title">Khách</div>

        <NavLink class="menu-link" href="" Match="NavLinkMatch.All">
            <i class="bi bi-house-door"></i>
            <span>Trang chủ</span>
        </NavLink>

        <NavLink class="menu-link" href="books">
            <i class="bi bi-book"></i>
            <span>Danh sách sách</span>
        </NavLink>

        <NavLink class="menu-link" href="search-books">
            <i class="bi bi-search"></i>
            <span>Tìm kiếm sách</span>
        </NavLink>

        <NavLink class="menu-link" href="book-detail">
            <i class="bi bi-info-circle"></i>
            <span>Thông tin sách</span>
        </NavLink>
        <NavLink class="menu-link" href="library-info">
            <i class="bi bi-info-square"></i>
            <span>Thông tin thư viện</span>
        </NavLink>


        @if (IsMemberOrHigher)
        {
            <div class="menu-title">Thành viên</div>

            <NavLink class="menu-link" href="borrow-request">
                <i class="bi bi-send"></i>
                <span>Gửi yêu cầu mượn</span>
            </NavLink>

            <NavLink class="menu-link" href="borrow-history">
                <i class="bi bi-clock-history"></i>
                <span>Lịch sử mượn</span>
            </NavLink>

            <NavLink class="menu-link" href="request-status">
                <i class="bi bi-hourglass-split"></i>
                <span>Trạng thái yêu cầu</span>
            </NavLink>
        }


        @if (IsLibrarianOrAdmin)
        {
            <div class="menu-title">Thủ thư</div>

            <NavLink class="menu-link" href="manage-books">
                <i class="bi bi-journal-plus"></i>
                <span>Quản lý sách</span>
            </NavLink>

            <NavLink class="menu-link" href="approve-borrow">
                <i class="bi bi-check2-square"></i>
                <span>Duyệt yêu cầu mượn</span>
            </NavLink>

            <NavLink class="menu-link" href="return-books">
                <i class="bi bi-arrow-return-left"></i>
                <span>Xác nhận trả sách</span>
            </NavLink>

            <NavLink class="menu-link" href="overdue-books">
                <i class="bi bi-exclamation-triangle"></i>
                <span>Sách quá hạn</span>
            </NavLink>
        }


        @if (IsAdmin)
        {
            <div class="menu-title">Quản trị</div>

            <NavLink class="menu-link" href="accounts">
                <i class="bi bi-person-gear"></i>
                <span>Quản lý tài khoản</span>
            </NavLink>

            <NavLink class="menu-link" href="system">
                <i class="bi bi-sliders"></i>
                <span>Quản lý hệ thống</span>
            </NavLink>

            <NavLink class="menu-link" href="statistics">
                <i class="bi bi-bar-chart"></i>
                <span>Thống kê hoạt động</span>
            </NavLink>
        }

    </nav>

    <div class="sidebar-bottom">

        @if (isLoggedIn)
        {
            <button class="menu-link logout logout-button" @onclick="Logout">
                <i class="bi bi-box-arrow-left"></i>
                <span>Đăng xuất</span>
            </button>
        }

        <div class="dark-mode">
            <div>
                <i class="bi bi-moon"></i>
                <span>Dark Mode</span>
            </div>

            <label class="switch">
                <input type="checkbox" 
                       checked="@isDarkMode"
                       @onchange="ToggleDarkMode" />
                <span></span>
            </label>
        </div>
    </div>

</div>

@code {
    [Parameter] public bool IsCollapsed { get; set; }
    [Parameter] public EventCallback ToggleSidebar { get; set; }

    private string role = "";
    private bool isLoggedIn = false;
    private bool isDarkMode = false;

    private bool IsAdmin => role == "Admin";

    private bool IsLibrarianOrAdmin =>
        role == "Librarian" || role == "Admin";

    private bool IsMemberOrHigher =>
        role == "Member" || role == "Librarian" || role == "Admin";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CheckLoginStatus();
            await LoadDarkMode();
            StateHasChanged();
        }
    }

    private async Task CheckLoginStatus()
    {
        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        var expirationText = await JS.InvokeAsync<string?>("localStorage.getItem", "tokenExpiration");

        if (string.IsNullOrWhiteSpace(token) || string.IsNullOrWhiteSpace(expirationText))
        {
            role = "";
            isLoggedIn = false;
            return;
        }

        if (!DateTime.TryParse(expirationText, out DateTime expiration))
        {
            await ClearAuthData();
            return;
        }

        if (DateTime.Now >= expiration)
        {
            await ClearAuthData();
            return;
        }

        role = await JS.InvokeAsync<string?>("localStorage.getItem", "role") ?? "";
        isLoggedIn = true;
    }

    private async Task ClearAuthData()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        await JS.InvokeVoidAsync("localStorage.removeItem", "username");
        await JS.InvokeVoidAsync("localStorage.removeItem", "gmail");
        await JS.InvokeVoidAsync("localStorage.removeItem", "role");
        await JS.InvokeVoidAsync("localStorage.removeItem", "tokenExpiration");

        role = "";
        isLoggedIn = false;
    }

    private async Task Logout()
    {
        bool confirmLogout = await JS.InvokeAsync<bool>(
            "confirm",
            "Bạn có chắc chắn muốn đăng xuất không?"
        );

        if (!confirmLogout)
        {
            return;
        }
        await ClearAuthData();
        Navigation.NavigateTo("/", forceLoad: true);
    }
    private async Task LoadDarkMode()
    {
        var savedTheme = await JS.InvokeAsync<string?>("localStorage.getItem", "theme");

        isDarkMode = savedTheme == "dark";

        if (isDarkMode)
        {
            await JS.InvokeVoidAsync("document.body.classList.add", "dark-mode-active");
        }
        else
        {
            await JS.InvokeVoidAsync("document.body.classList.remove", "dark-mode-active");
        }
    }

    private async Task ToggleDarkMode(ChangeEventArgs e)
    {
        isDarkMode = (bool)e.Value!;

        if (isDarkMode)
        {
            await JS.InvokeVoidAsync("document.body.classList.add", "dark-mode-active");
            await JS.InvokeVoidAsync("localStorage.setItem", "theme", "dark");
        }
        else
        {
            await JS.InvokeVoidAsync("document.body.classList.remove", "dark-mode-active");
            await JS.InvokeVoidAsync("localStorage.setItem", "theme", "light");
        }
    }
}