@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page">

    <aside class="sidebar @(isCollapsed ? "collapsed" : "")">
        <NavMenu IsCollapsed="isCollapsed"
                 ToggleSidebar="ToggleSidebar" />
    </aside>

    <main class="main">

        <header class="topbar">
            <div class="topbar-left">
                <h2>LibraryPro</h2>
                <p>Nền tảng quản lý thư viện trực tuyến</p>
            </div>

            <div class="topbar-right">
                <button class="notification-btn">
                    <i class="bi bi-bell"></i>
                </button>

                @if (isLoggedIn)
                {
                    <div class="user-box">
                        <div class="user-avatar">
                            @GetAvatarText()
                        </div>

                        <div class="user-info">
                            <strong>@username</strong>
                            <span>@role</span>
                        </div>

                        <button class="logout-btn" @onclick="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </div>
                }
                else
                {
                    <button class="login-btn" @onclick="GoToLogin">
                        <i class="bi bi-person-circle"></i>
                        <span>Đăng nhập</span>
                    </button>
                }
            </div>
        </header>

        <article class="content">
            @Body
        </article>

    </main>

</div>

@code {
    private bool isCollapsed = false;
    private bool isLoggedIn = false;
    private string username = "";
    private string role = "";

    private PeriodicTimer? tokenTimer;
    private CancellationTokenSource? timerCts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUserFromLocalStorage();
            StartTokenChecker();
            StateHasChanged();
        }
    }

    private async Task LoadUserFromLocalStorage()
    {
        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        var expirationText = await JS.InvokeAsync<string?>("localStorage.getItem", "tokenExpiration");

        if (string.IsNullOrWhiteSpace(token) || string.IsNullOrWhiteSpace(expirationText))
        {
            ClearUserState();
            return;
        }

        if (!DateTime.TryParse(expirationText, out DateTime expiration))
        {
            await ClearAuthData();
            return;
        }

        if (DateTime.Now >= expiration)
        {
            await HandleTokenExpired();
            return;
        }

        username = await JS.InvokeAsync<string?>("localStorage.getItem", "username") ?? "";
        role = await JS.InvokeAsync<string?>("localStorage.getItem", "role") ?? "";

        isLoggedIn = true;
    }

    private void StartTokenChecker()
    {
        timerCts = new CancellationTokenSource();

        // Kiểm tra mỗi 10 giây
        tokenTimer = new PeriodicTimer(TimeSpan.FromSeconds(10));

        _ = CheckTokenLoop();
    }

    private async Task CheckTokenLoop()
    {
        if (tokenTimer == null || timerCts == null)
        {
            return;
        }

        try
        {
            while (await tokenTimer.WaitForNextTickAsync(timerCts.Token))
            {
                await InvokeAsync(async () =>
                {
                    if (!isLoggedIn)
                    {
                        return;
                    }

                    var expirationText = await JS.InvokeAsync<string?>("localStorage.getItem", "tokenExpiration");

                    if (string.IsNullOrWhiteSpace(expirationText))
                    {
                        await HandleTokenExpired();
                        return;
                    }

                    if (!DateTime.TryParse(expirationText, out DateTime expiration))
                    {
                        await HandleTokenExpired();
                        return;
                    }

                    if (DateTime.Now >= expiration)
                    {
                        await HandleTokenExpired();
                    }
                });
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task HandleTokenExpired()
    {
        await ClearAuthData();

        await JS.InvokeVoidAsync(
            "alert",
            "Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại."
        );

        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task Logout()
    {
        await ClearAuthData();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private async Task ClearAuthData()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        await JS.InvokeVoidAsync("localStorage.removeItem", "username");
        await JS.InvokeVoidAsync("localStorage.removeItem", "gmail");
        await JS.InvokeVoidAsync("localStorage.removeItem", "role");
        await JS.InvokeVoidAsync("localStorage.removeItem", "tokenExpiration");

        ClearUserState();
        StateHasChanged();
    }

    private void ClearUserState()
    {
        isLoggedIn = false;
        username = "";
        role = "";
    }

    private string GetAvatarText()
    {
        if (string.IsNullOrWhiteSpace(username))
        {
            return "U";
        }

        return username.Substring(0, 1).ToUpper();
    }

    public async ValueTask DisposeAsync()
    {
        if (timerCts != null)
        {
            await timerCts.CancelAsync();
            timerCts.Dispose();
        }

        tokenTimer?.Dispose();
    }
}