@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="page">

    <aside class="sidebar @(isCollapsed ? "collapsed" : "")">
        <NavMenu IsCollapsed="isCollapsed"
                 ToggleSidebar="ToggleSidebar" />
    </aside>

    <main class="main">

        <header class="topbar">
            <div class="topbar-left">
                <h2>LibraryPro</h2>
                <p>Nền tảng quản lý thư viện trực tuyến</p>
            </div>

            <div class="topbar-right">
                <button class="notification-btn">
                    <i class="bi bi-bell"></i>
                </button>

                @if (isLoggedIn)
                {
                    <div class="user-box">
                        <div class="user-avatar">
                            @GetAvatarText()
                        </div>

                        <div class="user-info">
                            <strong>@username</strong>
                            <span>@role</span>
                        </div>

                        <button class="logout-btn" @onclick="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </div>
                }
                else
                {
                    <button class="login-btn" @onclick="GoToLogin">
                        <i class="bi bi-person-circle"></i>
                        <span>Đăng nhập</span>
                    </button>
                }
            </div>
        </header>

        <article class="content">
            @Body
        </article>

    </main>

</div>

@code {
    private bool isCollapsed = false;
    private bool isLoggedIn = false;
    private string username = "";
    private string role = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadUserFromLocalStorage();
            StateHasChanged();
        }
    }

    private async Task LoadUserFromLocalStorage()
    {
        var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
        username = await JS.InvokeAsync<string?>("localStorage.getItem", "username") ?? "";
        role = await JS.InvokeAsync<string?>("localStorage.getItem", "role") ?? "";

        isLoggedIn = !string.IsNullOrWhiteSpace(token);
    }

    private void ToggleSidebar()
    {
        isCollapsed = !isCollapsed;
    }

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        await JS.InvokeVoidAsync("localStorage.removeItem", "username");
        await JS.InvokeVoidAsync("localStorage.removeItem", "gmail");
        await JS.InvokeVoidAsync("localStorage.removeItem", "role");

        isLoggedIn = false;
        username = "";
        role = "";

        Navigation.NavigateTo("/", forceLoad: true);
    }

    private string GetAvatarText()
    {
        if (string.IsNullOrWhiteSpace(username))
        {
            return "U";
        }

        return username.Substring(0, 1).ToUpper();
    }
}